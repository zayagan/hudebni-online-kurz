PORT=8000
APP_URL=http://localhost:8000

# Stripe test keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
OPENAI_API_KEY=sk-proj-xxx

# Currency + amounts (default: CZK 200 one-time / CZK 100 monthly)
STRIPE_CURRENCY=czk
STRIPE_AMOUNT_ONE_TIME=200
STRIPE_AMOUNT_SUBSCRIPTION=100
# Optional: set true only if amount values are already in minor units (haléře/cents)
STRIPE_AMOUNTS_ARE_MINOR=false

# Optional: use existing Stripe Price IDs instead of dynamic price_data
# STRIPE_PRICE_ONE_TIME=price_xxx
# STRIPE_PRICE_SUBSCRIPTION=price_xxx
